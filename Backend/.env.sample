# ── CLAIMLENS EXPRESS BACKEND CONFIGURATION ────────────────────────────────

# Server Settings
PORT=5000

# Database Connections
# MongoDB Connection String (Local or MongoDB Atlas)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/claimlens?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_jwt_signing_secret_here

# Cloudinary Integration (Media Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Dispatch Settings (Nodemailer SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password_here
EMAIL_FROM="ClaimLens Support <your_email@gmail.com>"

# AI Pipeline Connection
# Use http://127.0.0.1:8000 for local dev or http://pipeline:8000 inside Docker Compose
FASTAPI_URL=http://127.0.0.1:8000

# Redis/BullMQ Configuration
# For local Redis, use REDIS_HOST & REDIS_PORT. For Upstash, use REDIS_URL.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_URL=rediss://default:token@liked-warthog-128233.upstash.io:6379
